# ─── Burnside Project Test Suite ─────────────────────────────────────────
# Copy to .env and adjust for your environment.
# All values shown are defaults — uncomment to override.
#
# Two paths:
#
#   Path A — I have production data:
#     1. pg_dump your production DB → local file
#     2. Set PG_DATABASE to match the DB name in your dump
#     3. Set SEED_SCHEMA=false (skip built-in e-commerce schema)
#     4. Run: make import DUMP=/path/to/production.dump
#     5. Run: make up INTENSITY=medium
#
#   Path B — I don't have production data:
#     1. Leave defaults (SEED_SCHEMA=true seeds 18-table e-commerce, ~30M rows)
#     2. Run: make up
#
# NOTE: pg-stress always runs its own PostgreSQL container.
# These variables configure that container — they do NOT connect to a
# remote/external database. To test production data, export a dump and
# import it with `make import`.

# ─── Server Identity ─────────────────────────────────────────────────────
# Displayed in the Control Panel UI so you know which server you're on.
# PG_HOST=localhost                    # Hostname or IP shown in the UI

# ─── Database Target ─────────────────────────────────────────────────────
# Credentials and database name for the LOCAL PostgreSQL container.
# All services (load generators, dashboard, analyzer) share these.
# PG_HOST configures both the display name and server identity.
# PG_USER=postgres
# PG_PASSWORD=postgres
# PG_DATABASE=testdb                  # Set to your dump's DB name for Path A

# ─── Schema Seeding ─────────────────────────────────────────────────────
# SEED_SCHEMA=true                    # true  = seed built-in 18-table e-commerce schema (Path B)
                                      # false = skip seeding, use your own dump (Path A)

# ─── Intensity Preset ───────────────────────────────────────────────────
# INTENSITY=medium                    # low | medium | high (via Makefile)

# ─── Scenario ────────────────────────────────────────────────────────────
# SCENARIO=default                    # default | heavy | gentle

# ─── PostgreSQL Tuning (built-in container only) ─────────────────────────
# PG_PORT=5434                        # Host port for postgres
# PG_SHARED_BUFFERS=256MB
# PG_WORK_MEM=16MB
# PG_MAX_CONNECTIONS=200
# PG_EFFECTIVE_CACHE_SIZE=1GB

# ─── Raw SQL Load Generator (Go) ────────────────────────────────────────
# LOADGEN_DURATION=0                  # 0 = run forever, or e.g. 30m, 2h
# LOADGEN_MIX_BROWSE=50
# LOADGEN_MIX_CART=20
# LOADGEN_MIX_CHECKOUT=5
# LOADGEN_MIX_ORDER=10
# LOADGEN_MIX_BACKGROUND=10
# LOADGEN_MIX_REPORTING=5
# LOADGEN_BURST_LOW_CONNS=5
# LOADGEN_BURST_LOW_DURATION=10s
# LOADGEN_BURST_LOW_WEIGHT=50
# LOADGEN_BURST_MED_CONNS=20
# LOADGEN_BURST_MED_DURATION=30s
# LOADGEN_BURST_MED_WEIGHT=35
# LOADGEN_BURST_HEAVY_CONNS=50
# LOADGEN_BURST_HEAVY_DURATION=60s
# LOADGEN_BURST_HEAVY_WEIGHT=15
# LOADGEN_CHAOS_ENABLED=true
# LOADGEN_CHAOS_PROBABILITY=25
# LOADGEN_PAUSE_MIN=20
# LOADGEN_PAUSE_MAX=90
# LOADGEN_MAX_POOL=60

# ─── ORM Load Generator (SQLAlchemy) ────────────────────────────────────
# ORM_CONCURRENCY=5
# ORM_DURATION=0
# ORM_PAUSE_MIN=10
# ORM_PAUSE_MAX=50
# ORM_MIX_N_PLUS_1=15
# ORM_MIX_EAGER_JOIN=15
# ORM_MIX_EAGER_SUBQUERY=10
# ORM_MIX_EAGER_SELECTIN=10
# ORM_MIX_BULK_INSERT=5
# ORM_MIX_ORM_UPDATE=10
# ORM_MIX_PAGINATION=10
# ORM_MIX_AGGREGATION=10
# ORM_MIX_EXISTS_FILTER=10
# ORM_MIX_RELATIONSHIP=5
# ORM_STATS_INTERVAL=30

# ─── pgbench Runner ─────────────────────────────────────────────────────
# PGBENCH_CLIENTS=10
# PGBENCH_THREADS=2
# PGBENCH_DURATION=300                # seconds
# PGBENCH_SCALE=100
# PGBENCH_MODE=mixed                  # tpcb | readonly | mixed | custom

# ─── Dashboard ───────────────────────────────────────────────────────────
# DASHBOARD_PORT=8200
# STRESS_POLL_INTERVAL=10
# STRESS_SAFETY_INTERVAL=30
# STRESS_MAX_DB_SIZE=20000000000
# STRESS_LIMIT_SEARCH_LOG=5000000
# STRESS_LIMIT_AUDIT_LOG=5000000
# STRESS_LIMIT_PRICE_HISTORY=2000000
# STRESS_LIMIT_CART_ITEMS=1000000
# STRESS_LIMIT_REVIEWS=5000000

# ─── Collector + Truth Service ───────────────────────────────────────────
# COLLECTOR_PORT=8080
# TRUTH_PORT=8001

# ─── Control Plane ───────────────────────────────────────────────────────
# CONTROL_PLANE_PORT=8100

# ─── AI Analyzer (Claude-powered) ────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        # Required for analyze endpoints
# ANALYZER_MODEL=claude-sonnet-4-20250514  # or claude-opus-4-20250514

# ─── Production Queries ──────────────────────────────────────────────────
# QUERIES_DIR=./queries               # Drop .sql files here for replay
                                      # Also supports queries.json (pg_stat_statements export)

# ─── Reports ────────────────────────────────────────────────────────────
# REPORTS_DIR=/app/reports            # Where AI analysis and ladder reports are saved
                                      # Mapped to Docker volume: control-plane-reports

# ─── Remote Deployment () ───────────────────────────
# DEPLOY_HOST=YOUR HOST                  # SSH alias or hostname
# DEPLOY_PATH=/opt/burnside-test-suite
# DEPLOY_USER=HOST USER TO DEPLOY DOCKER IMAGE