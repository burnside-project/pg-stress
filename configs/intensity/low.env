# pg-stress Intensity: LOW
# Light load for development, BYOD validation, and collector testing.
# Safe for small databases. No chaos. Minimal connection pressure.

# ── Raw SQL Load Generator ───────────────────────────────────────────────
LOADGEN_MIX_BROWSE=60
LOADGEN_MIX_CART=15
LOADGEN_MIX_CHECKOUT=3
LOADGEN_MIX_ORDER=7
LOADGEN_MIX_BACKGROUND=10
LOADGEN_MIX_REPORTING=5
LOADGEN_BURST_LOW_CONNS=3
LOADGEN_BURST_LOW_DURATION=10s
LOADGEN_BURST_LOW_WEIGHT=70
LOADGEN_BURST_MED_CONNS=8
LOADGEN_BURST_MED_DURATION=20s
LOADGEN_BURST_MED_WEIGHT=25
LOADGEN_BURST_HEAVY_CONNS=15
LOADGEN_BURST_HEAVY_DURATION=30s
LOADGEN_BURST_HEAVY_WEIGHT=5
LOADGEN_CHAOS_ENABLED=false
LOADGEN_CHAOS_PROBABILITY=0
LOADGEN_PAUSE_MIN=30
LOADGEN_PAUSE_MAX=120
LOADGEN_MAX_POOL=20

# ── ORM Load Generator ──────────────────────────────────────────────────
ORM_CONCURRENCY=2
ORM_PAUSE_MIN=50
ORM_PAUSE_MAX=200
ORM_MIX_N_PLUS_1=10
ORM_MIX_EAGER_JOIN=20
ORM_MIX_EAGER_SUBQUERY=15
ORM_MIX_EAGER_SELECTIN=15
ORM_MIX_BULK_INSERT=5
ORM_MIX_ORM_UPDATE=5
ORM_MIX_PAGINATION=10
ORM_MIX_AGGREGATION=10
ORM_MIX_EXISTS_FILTER=5
ORM_MIX_RELATIONSHIP=5

# ── pgbench ──────────────────────────────────────────────────────────────
PGBENCH_CLIENTS=5
PGBENCH_THREADS=2
PGBENCH_SCALE=50

# ── Safety Limits ────────────────────────────────────────────────────────
STRESS_MAX_DB_SIZE=15000000000
STRESS_LIMIT_SEARCH_LOG=2000000
STRESS_LIMIT_AUDIT_LOG=2000000
STRESS_LIMIT_PRICE_HISTORY=1000000
STRESS_LIMIT_CART_ITEMS=500000
STRESS_LIMIT_REVIEWS=2000000
