# pg-stress Intensity: HIGH
# Heavy stress with high connection counts, frequent chaos, short pauses.
# Designed to find breaking points. May cause deadlocks and temp spills.

# ── Raw SQL Load Generator ───────────────────────────────────────────────
LOADGEN_MIX_BROWSE=40
LOADGEN_MIX_CART=25
LOADGEN_MIX_CHECKOUT=10
LOADGEN_MIX_ORDER=10
LOADGEN_MIX_BACKGROUND=10
LOADGEN_MIX_REPORTING=5
LOADGEN_BURST_LOW_CONNS=15
LOADGEN_BURST_LOW_DURATION=15s
LOADGEN_BURST_LOW_WEIGHT=20
LOADGEN_BURST_MED_CONNS=40
LOADGEN_BURST_MED_DURATION=45s
LOADGEN_BURST_MED_WEIGHT=40
LOADGEN_BURST_HEAVY_CONNS=80
LOADGEN_BURST_HEAVY_DURATION=90s
LOADGEN_BURST_HEAVY_WEIGHT=40
LOADGEN_CHAOS_ENABLED=true
LOADGEN_CHAOS_PROBABILITY=50
LOADGEN_PAUSE_MIN=5
LOADGEN_PAUSE_MAX=20
LOADGEN_MAX_POOL=100

# ── ORM Load Generator ──────────────────────────────────────────────────
ORM_CONCURRENCY=15
ORM_PAUSE_MIN=5
ORM_PAUSE_MAX=20
ORM_MIX_N_PLUS_1=20
ORM_MIX_EAGER_JOIN=15
ORM_MIX_EAGER_SUBQUERY=10
ORM_MIX_EAGER_SELECTIN=10
ORM_MIX_BULK_INSERT=10
ORM_MIX_ORM_UPDATE=10
ORM_MIX_PAGINATION=5
ORM_MIX_AGGREGATION=5
ORM_MIX_EXISTS_FILTER=10
ORM_MIX_RELATIONSHIP=5

# ── pgbench ──────────────────────────────────────────────────────────────
PGBENCH_CLIENTS=50
PGBENCH_THREADS=8
PGBENCH_SCALE=200

# ── Safety Limits ────────────────────────────────────────────────────────
STRESS_MAX_DB_SIZE=30000000000
STRESS_LIMIT_SEARCH_LOG=5000000
STRESS_LIMIT_AUDIT_LOG=5000000
STRESS_LIMIT_PRICE_HISTORY=2000000
STRESS_LIMIT_CART_ITEMS=1000000
STRESS_LIMIT_REVIEWS=5000000
