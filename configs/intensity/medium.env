# pg-stress Intensity: MEDIUM
# Standard OLTP stress test. Moderate burst intensity.
# Chaos enabled at 25%. Good baseline for most production databases.

# ── Raw SQL Load Generator ───────────────────────────────────────────────
LOADGEN_MIX_BROWSE=50
LOADGEN_MIX_CART=20
LOADGEN_MIX_CHECKOUT=5
LOADGEN_MIX_ORDER=10
LOADGEN_MIX_BACKGROUND=10
LOADGEN_MIX_REPORTING=5
LOADGEN_BURST_LOW_CONNS=5
LOADGEN_BURST_LOW_DURATION=10s
LOADGEN_BURST_LOW_WEIGHT=50
LOADGEN_BURST_MED_CONNS=20
LOADGEN_BURST_MED_DURATION=30s
LOADGEN_BURST_MED_WEIGHT=35
LOADGEN_BURST_HEAVY_CONNS=50
LOADGEN_BURST_HEAVY_DURATION=60s
LOADGEN_BURST_HEAVY_WEIGHT=15
LOADGEN_CHAOS_ENABLED=true
LOADGEN_CHAOS_PROBABILITY=25
LOADGEN_PAUSE_MIN=20
LOADGEN_PAUSE_MAX=90
LOADGEN_MAX_POOL=60

# ── ORM Load Generator ──────────────────────────────────────────────────
ORM_CONCURRENCY=5
ORM_PAUSE_MIN=10
ORM_PAUSE_MAX=50
ORM_MIX_N_PLUS_1=15
ORM_MIX_EAGER_JOIN=15
ORM_MIX_EAGER_SUBQUERY=10
ORM_MIX_EAGER_SELECTIN=10
ORM_MIX_BULK_INSERT=5
ORM_MIX_ORM_UPDATE=10
ORM_MIX_PAGINATION=10
ORM_MIX_AGGREGATION=10
ORM_MIX_EXISTS_FILTER=10
ORM_MIX_RELATIONSHIP=5

# ── pgbench ──────────────────────────────────────────────────────────────
PGBENCH_CLIENTS=10
PGBENCH_THREADS=2
PGBENCH_SCALE=100

# ── Safety Limits ────────────────────────────────────────────────────────
STRESS_MAX_DB_SIZE=20000000000
STRESS_LIMIT_SEARCH_LOG=5000000
STRESS_LIMIT_AUDIT_LOG=5000000
STRESS_LIMIT_PRICE_HISTORY=2000000
STRESS_LIMIT_CART_ITEMS=1000000
STRESS_LIMIT_REVIEWS=5000000
